<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_modal">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Tambah Transaksi"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="#111"
                android:layout_alignParentStart="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <ImageView
                android:id="@+id/btnClose"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#555"
                android:layout_alignParentEnd="true"
                android:layout_width="30dp"
                android:layout_height="30dp"/>

        </RelativeLayout>

        <!-- TOGGLE -->
        <LinearLayout
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="56dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPengeluaran"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Pengeluaran"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/bg_toggle_red"
                android:backgroundTint="@null"/>

            <Space
                android:layout_width="12dp"
                android:layout_height="match_parent"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPemasukan"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Pemasukan"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="#222"
                android:background="@drawable/bg_toggle_gray"
                android:backgroundTint="@null"/>

        </LinearLayout>

        <!-- JUDUL -->
        <TextView
            android:text="Judul"
            android:textSize="15sp"
            android:textColor="#000"
            android:layout_marginTop="22dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/etTitle"
            android:hint="Beli Jajan"
            android:background="@drawable/bg_input"
            android:padding="16dp"
            android:textSize="16sp"
            android:layout_marginTop="6dp"
            android:layout_width="match_parent"
            android:layout_height="54dp"/>

        <!-- JUMLAH -->
        <TextView
            android:text="Jumlah"
            android:textSize="15sp"
            android:textColor="#000"
            android:layout_marginTop="18dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/etAmount"
            android:hint="Rp 0"
            android:background="@drawable/bg_input"
            android:padding="16dp"
            android:textSize="16sp"
            android:inputType="number"
            android:layout_marginTop="6dp"
            android:layout_width="match_parent"
            android:layout_height="54dp"/>

        <!-- UPLOAD STRUK -->
        <TextView
            android:text="Upload Struk"
            android:textSize="15sp"
            android:textColor="#000"
            android:layout_marginTop="18dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <FrameLayout
            android:id="@+id/uploadArea"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_upload">

            <!-- Placeholder -->
            <LinearLayout
                android:id="@+id/layoutPlaceholder"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:src="@android:drawable/ic_menu_upload"
                    android:tint="#999"
                    android:layout_width="28dp"
                    android:layout_height="28dp"/>

                <TextView
                    android:text="Klik untuk upload struk"
                    android:textColor="#777"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- Preview Image -->
            <ImageView
                android:id="@+id/imgPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"/>

        </FrameLayout>

        <!-- DESKRIPSI -->
        <TextView
            android:text="Deskripsi"
            android:textSize="15sp"
            android:textColor="#000"
            android:layout_marginTop="18dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input"
            android:hint="Masukkan deskripsi"
            android:padding="16dp" />

        <!-- TANGGAL -->
        <TextView
            android:text="Tanggal"
            android:textSize="15sp"
            android:textColor="#000"
            android:layout_marginTop="18dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/inputTanggal"
            android:focusable="false"
            android:clickable="true"
            android:text="01/04/2026"
            android:drawableEnd="@android:drawable/ic_menu_my_calendar"
            android:background="@drawable/bg_input"
            android:padding="16dp"
            android:layout_marginTop="6dp"
            android:layout_width="match_parent"
            android:layout_height="54dp"/>

        <!-- BUTTON SIMPAN -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSimpan"
            style="@style/Widget.AppCompat.Button"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="26dp"
            android:layout_marginBottom="20dp"
            android:text="Simpan Transaksi"
            android:textAllCaps="false"
            android:textSize="17sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_gradient"
            android:backgroundTint="@null"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>